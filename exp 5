# Importing Dependencies
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
# Load Dataset
df = pd.read_csv("/content/E05_Iris-flower_Dataset.csv")
# Display dataset
print(df)
# Shape of dataset
print(df.shape)
# Statistical Summary
print(df.describe())
# Mean values grouped by Species
print(df.groupby('Species').mean())
