

# Import necessary libraries
import numpy as np
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
# EXP NO . 4(PCA)
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler, LabelEncoder
# Load the MPG Dataset
mpg_df = sns.load_dataset('mpg')
# Display statistical summary
print(mpg_df.describe())
# Handling missing values
# Replacing NaN values in horsepower with mean value
mpg_df['horsepower'] = mpg_df['horsepower'].fillna(mpg_df['horsepower'].mean())
# Encoding categorical variables
encoder = LabelEncoder()
mpg_df['origin'] = encoder.fit_transform(mpg_df['origin'])
mpg_df['name'] = encoder.fit_transform(mpg_df['name'])
# Selecting features for PCA
X = mpg_df.drop(columns=['mpg'])
# Standardizing the data
# PCA is sensitive to scale
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
# Applying PCA
pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)
# Convert PCA results into DataFrame
pca_df = pd.DataFrame(
    X_pca,
    columns=['PC1', 'PC2']
)
# Explained variance ratio
print("Explained Variance Ratio:")
print(pca.explained_variance_ratio_)
# Scatter plot of PCA components
plt.figure(figsize=(8, 6))
plt.scatter(
    pca_df['PC1'],
    pca_df['PC2'],
    alpha=0.7,
    c=mpg_df['origin'],
    cmap='viridis'
)
plt.colorbar(label='Origin')
plt.xlabel('Principal Component 1')
plt.ylabel('Principal Component 2')
plt.title("PCA of MPG Dataset")
plt.show()
