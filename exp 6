import pandas as pd
import numpy as np
# EXP NO 6(House Price Prediction)
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import OrdinalEncoder
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction import DictVectorizer
from sklearn.linear_model import LinearRegression
from sklearn.metrics import (
    mean_absolute_error,
    mean_squared_error,
    r2_score
)
# Load Dataset
df = pd.read_csv("/content/E06_house price data less.csv")
# Display first 10 rows
print(df.head(10))
# Dataset Shape
print(df.shape)
# Check missing values
print(df.isnull().sum())
# Data types
print(df.dtypes)
# Statistical Summary
print(df.describe())
# Pre-processing
# Drop unnecessary columns
df.drop('ID', axis=1, inplace=True)
df.drop('Locality', axis=1, inplace=True)
# Ordinal Encoding
ordinal_columns = [
    'Property_Type',
    'Furnished_Status',
    'Public_Transport_Accessibility',
    'Facing',
    'Security'
]
categories = [
    ['Apartment', 'Independent House', 'Villa'],
    ['Unfurnished', 'Semi-furnished', 'Furnished'],
    ['Low', 'Medium', 'High'],
    ['South', 'East', 'West', 'North'],
    ['No', 'Yes']
]
encoder = OrdinalEncoder(categories=categories)
df[ordinal_columns] = encoder.fit_transform(df[ordinal_columns])
# Separate categorical and numerical columns
categorical_col = [
    column for column in df.columns
    if df[column].dtype == 'object'
]
numerical_col = [
    column for column in df.columns
    if df[column].dtype != 'object'
]
# Convert categorical text to lowercase
for column in categorical_col:
    df[column] = df[column].str.lower()
# Correlation Matrix
correlation_matrix = df[numerical_col].corr()
# Heatmap
plt.figure(figsize=(8, 6))
sns.heatmap(
    correlation_matrix,
    cmap='coolwarm',
    fmt=".2f",
    linewidths=0.5
)
plt.title("Correlation Heatmap")
plt.show()
# Randomly sample 40% of the data
df_sampled = df.sample(frac=0.4, random_state=1)
# Features and Target
X = df_sampled.drop('Price_in_Lakhs', axis=1)
y = df_sampled['Price_in_Lakhs']
# Train-Test Split
X_train, X_test, y_train, y_test = train_test_split(
X, 
y,
test_size=0.2,
random_state=1
)
# Convert to dictionary format
train_dicts = X_train.to_dict(orient='records')
test_dicts = X_test.to_dict(orient='records')
# Encode categorical variables
dv = DictVectorizer(sparse=False)
X_train = dv.fit_transform(train_dicts)
X_test = dv.transform(test_dicts)
# Train Linear Regression Model
model = LinearRegression()
model.fit(X_train, y_train)
# Predictions
y_pred = model.predict(X_test)
# Evaluation Function
def evaluate_model(y, y_pred):
    mae = mean_absolute_error(y, y_pred)
    mse = mean_squared_error(y, y_pred)
    rmse = np.sqrt(mse)
    r2 = r2_score(y, y_pred)
    return mae, mse, rmse, r2
# Evaluate Model
mae, mse, rmse, r2 = evaluate_model(y_test, y_pred)
print("MAE:", mae)
print("MSE:", mse)
print("RMSE:", rmse)
print("R2 Score:", r2)
